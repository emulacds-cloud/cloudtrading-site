{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/analise", "destination": "/analise/index.html" },
    { "source": "/analise/(.*)", "destination": "/analise/index.html" }
  ]
}
